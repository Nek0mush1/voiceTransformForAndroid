<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/ime_panel_background"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingTop="10dp"
    android:paddingRight="12dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/imeStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:minHeight="24dp"
            android:text="Ready"
            android:textColor="@color/ime_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/language_switch_background"
            android:orientation="horizontal"
            android:padding="2dp">

            <Button
                android:id="@+id/imeChineseButton"
                style="@style/ImeLanguageButton"
                android:text="@string/lang_zh" />

            <Button
                android:id="@+id/imeEnglishButton"
                style="@style/ImeLanguageButton"
                android:text="@string/lang_en" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/imeResultPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/ime_result_background"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/imeRawText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/ime_text_secondary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/imeRawToggleButton"
                style="@style/ImeTextButton"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/imeCorrectedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/ime_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/imeCorrectionMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/ime_text_secondary"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/imeInsertCorrectedButton"
                style="@style/ImePrimaryButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1.2"
                android:text="@string/ime_insert_corrected" />

            <Button
                android:id="@+id/imeInsertRawButton"
                style="@style/ImeSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/ime_insert_raw" />

            <Button
                android:id="@+id/imeCancelButton"
                style="@style/ImeSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="0.8"
                android:text="@string/ime_cancel" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/imeVoiceButton"
        style="@style/ImePrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="@string/ime_voice" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/imeDeleteButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/ime_delete" />

        <Button
            android:id="@+id/imeSpaceButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1.8"
            android:text="@string/ime_space" />

        <Button
            android:id="@+id/imeEnterButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/ime_enter" />
    </LinearLayout>
</LinearLayout>
