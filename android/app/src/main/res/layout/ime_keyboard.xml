<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/screen_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/imeStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:minHeight="32dp"
        android:text="Ready"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/imeVoiceButton"
            style="@style/ImePrimaryButton"
            android:layout_width="0dp"
            android:layout_weight="1.4"
            android:text="@string/ime_voice" />

        <Button
            android:id="@+id/imeDeleteButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/ime_delete" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/imeSwitchButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="@string/ime_switch" />

        <Button
            android:id="@+id/imeSpaceButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1.6"
            android:text="@string/ime_space" />

        <Button
            android:id="@+id/imeEnterButton"
            style="@style/ImeSecondaryButton"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/ime_enter" />
    </LinearLayout>
</LinearLayout>
